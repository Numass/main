local _enc=""
local _load=load or loadstring
local _dec=function(s)
    local b64="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    local t={} for i=1,#s,4 do
        local a,b,c,d=b64:find(s:sub(i,i))-1,b64:find(s:sub(i+1,i+1))-1,
            b64:find(s:sub(i+2,i+2))-1,b64:find(s:sub(i+3,i+3))-1
        local x=a*262144+b*4096+c*64+d
        t[#t+1]=string.char(x//65536,x//256%256,x%256)
    end
    return table.concat(t)
end
local _decomp=function(s)
    local data=_dec(s)
    local i=1
    return (loadstring or load)(data)
end
_decomp(_enc)()
